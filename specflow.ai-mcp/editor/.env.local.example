# Variáveis necessárias para o editor Next.js
# Adicione estas entradas no .env da raiz do projeto (specflow.ai-mcp/.env)
# ATENÇÃO: usar a anon key, NÃO a service key — o editor roda no browser
# (SUPABASE_URL e SUPABASE_SERVICE_KEY já existem no .env para o servidor MCP)

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# URL do servidor MCP — usada APENAS no servidor Next.js (API routes).
# O browser nunca acessa esta URL diretamente; ele chama /api/mcp (proxy local).
#
# Desenvolvimento local:
MCP_URL=http://localhost:3001/mcp
#
# Railway (setar no painel do serviço do editor, não precisa de NEXT_PUBLIC_):
# MCP_URL=https://specflowai.railway.internal/mcp
