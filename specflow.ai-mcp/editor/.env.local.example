# Variáveis necessárias para o editor Next.js
# Adicione estas duas entradas no .env da raiz do projeto (specflow.ai-mcp/.env)
# ATENÇÃO: usar a anon key, NÃO a service key — o editor roda no browser
# (SUPABASE_URL e SUPABASE_SERVICE_KEY já existem no .env para o servidor MCP)

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Desenvolvimento local — MCP server direto
# NEXT_PUBLIC_MCP_URL=http://localhost:3001/mcp

# Produção / Claude.ai — usar a URL pública do ngrok
NEXT_PUBLIC_MCP_URL=https://stress-gestation-domelike.ngrok-free.dev/mcp
